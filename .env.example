# Application
APP_NAME=thesis-financial-instruments-service
DEBUG=false

# Admin
ADMIN_API_KEY=change-me-in-production
# Public Streamlit demo gate
DEMO_PASSWORD=choose-a-strong-demo-password

# Database (docker-compose overrides this for containers)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docai

# Redis (docker-compose overrides this for containers)
REDIS_URL=redis://localhost:6379/0

# OCR
DEFAULT_OCR_ENGINE=tesseract
TESSERACT_CMD=tesseract
# Persistent Paddle model cache path (used when paddle extra is enabled)
PADDLE_PDX_CACHE_HOME=data/paddle-cache

# LLM
LLM_MODEL_PATH=models/qwen3-4b-instruct-2507-q5_k_m.gguf
LLM_N_CTX=6144
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.0
LLM_TOP_P=1.0
LLM_THREADS=8
LLM_MAX_RETRIES=2

# Storage
PROCESSED_DIR=data/processed
UPLOAD_DIR=data/uploads
COPY_SOURCE_PDF=false

# Security — semicolon-separated list of allowed root directories for file_path mode
ALLOWED_INPUT_ROOTS=

# Worker
WORKER_MAX_JOBS=1

# Docker build option (compose build arg): install PaddleOCR deps into image
# Set true only on compatible hosts (typically x86_64 Linux)
DOCKER_ENABLE_PADDLE=false
