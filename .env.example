# Application
APP_NAME=thesis-financial-instruments-service
DEBUG=false

# Admin
ADMIN_API_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docai

# Redis (for arq job queue)
REDIS_URL=redis://localhost:6379/0

# OCR
DEFAULT_OCR_ENGINE=tesseract
TESSERACT_CMD=tesseract

# LLM
LLM_MODEL_PATH=/models/qwen2.5-3b-instruct-q4_k_m.gguf
LLM_N_CTX=4096
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.0
LLM_TOP_P=1.0
LLM_THREADS=4
LLM_MAX_RETRIES=2

# Storage
PROCESSED_DIR=data/processed
COPY_SOURCE_PDF=false

# Security — semicolon-separated list of allowed root directories for file_path mode
ALLOWED_INPUT_ROOTS=

# Worker
WORKER_MAX_JOBS=2
